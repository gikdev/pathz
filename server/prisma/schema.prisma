// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

model Path {
  id    Int    @id @default(autoincrement())
  title String @db.VarChar(255)

  lessons PathLesson[]

  @@map("paths")
}

model Course {
  id          Int     @id @default(autoincrement())
  title       String  @db.VarChar(255)
  description String? @db.Text

  lessons Lesson[]

  @@map("courses")
}

model Lesson {
  id    Int    @id @default(autoincrement())
  title String @db.VarChar(255)

  course   Course @relation(fields: [courseId], references: [id])
  courseId Int

  pieces Piece[]
  paths  PathLesson[]

  @@map("lessons")
}

model Piece {
  id      Int       @id @default(autoincrement())
  type    PieceType
  payload String?   @db.MediumText
  order   Int

  lesson   Lesson @relation(fields: [lessonId], references: [id])
  lessonId Int

  @@map("pieces")
}

model PathLesson {
  id    Int @id @default(autoincrement())
  order Int

  path   Path @relation(fields: [pathId], references: [id])
  pathId Int

  lesson   Lesson @relation(fields: [lessonId], references: [id])
  lessonId Int

  @@map("path_lessons")
}

enum PieceType {
  Text
  Video
  Audio
  Separator
  Image
}
